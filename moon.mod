name = "hyl-star/moonsic"

version = "0.1.0"

import {
  "CAIMEOX/midi@0.1.0",
  "dowdiness/moondsp@0.5.1",
}

readme = "README.mbt.md"

repository = "https://github.com/hyl-star/moonsic"

license = "Apache-2.0"

keywords = [ "moonbit", "music", "midi", "musicxml", "wav" ]

description = "A MoonBit music IR and interoperability library with MIDI, MusicXML, WAV, and browser event export."
